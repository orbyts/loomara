---
import EntryHero from "../components/EntryHero.astro";
import systemFonts from "../data/system-fonts.json";
import SiteLayout from "../layouts/SiteLayout.astro";
import { site } from "../site.config";
---

<SiteLayout
  title="Hero Design Lab — suhail.ink"
  description="Local authoring workspace for the suhail.ink hero."
>
  <div class="design-lab-preview">
    <EntryHero
      contactHref={site.contactHref}
      instagramHref={site.instagramHref}
    />
  </div>

  <aside class="design-lab-panel" aria-label="Hero design controls">
    <header class="design-lab-panel__header">
      <div>
        <strong>Hero Design Lab</strong>
        <small>Settings are stored locally.</small>
      </div>
      <button type="button" data-reset>reset</button>
    </header>

    <details open>
      <summary>Canvas</summary>

      <label>
        <span>Background</span>
        <input type="color" value="#f3f1eb" data-css-var="--surface-page" />
      </label>

      <label>
        <span>Text</span>
        <input type="color" value="#171717" data-css-var="--text-primary" />
      </label>

      <label>
        <span>Whole hero X</span>
        <output></output>
        <input
          type="range"
          min="-10"
          max="10"
          step="0.1"
          value="0"
          data-css-var="--hero-center-x"
          data-unit="rem"
        />
      </label>

      <label>
        <span>Whole hero Y</span>
        <output></output>
        <input
          type="range"
          min="-10"
          max="10"
          step="0.1"
          value="0"
          data-css-var="--hero-center-y"
          data-unit="rem"
        />
      </label>
    </details>

    <details open>
      <summary>suhail</summary>

      <label class="wide">
        <span>Font family</span>
        <select data-css-var="--hero-name-font-family">
          <option value="Inter, ui-sans-serif, system-ui, sans-serif" selected>
            Inter / system fallback
          </option>
          <option value="-apple-system, BlinkMacSystemFont, sans-serif">
            Apple system
          </option>
          {
            systemFonts.map((font) => (
              <option value={`"${font}", sans-serif`}>{font}</option>
            ))
          }
        </select>
      </label>

      <label>
        <span>Size</span>
        <output></output>
        <input
          type="range"
          min="4"
          max="16"
          step="0.1"
          value="13"
          data-css-var="--hero-name-font-size"
          data-unit="rem"
        />
      </label>

      <label>
        <span>Weight</span>
        <output></output>
        <input
          type="range"
          min="100"
          max="900"
          step="10"
          value="760"
          data-css-var="--hero-name-font-weight"
        />
      </label>

      <label>
        <span>Tracking</span>
        <output></output>
        <input
          type="range"
          min="-0.15"
          max="0.08"
          step="0.001"
          value="-0.075"
          data-css-var="--hero-name-letter-spacing"
          data-unit="em"
        />
      </label>

      <label>
        <span>Line height</span>
        <output></output>
        <input
          type="range"
          min="0.6"
          max="1.3"
          step="0.01"
          value="0.82"
          data-css-var="--hero-name-line-height"
        />
      </label>

      <label>
        <span>Name X</span>
        <output></output>
        <input
          type="range"
          min="-1"
          max="1"
          step="0.005"
          value="0"
          data-css-var="--hero-name-x"
          data-unit="em"
        />
      </label>

      <label>
        <span>Name Y</span>
        <output></output>
        <input
          type="range"
          min="-1"
          max="1"
          step="0.005"
          value="0"
          data-css-var="--hero-name-y"
          data-unit="em"
        />
      </label>
    </details>

    <details open>
      <summary>Period</summary>

      <label>
        <span>Dot size</span>
        <output></output>
        <input
          type="range"
          min="0.03"
          max="0.25"
          step="0.002"
          value="0.105"
          data-css-var="--portal-dot-size"
          data-unit="em"
        />
      </label>

      <label>
        <span>Dot X</span>
        <output></output>
        <input
          type="range"
          min="0"
          max="100"
          step="0.5"
          value="50"
          data-css-var="--portal-dot-x"
          data-unit="%"
        />
      </label>

      <label>
        <span>Dot Y</span>
        <output></output>
        <input
          type="range"
          min="-200"
          max="600"
          step="0.5"
          value="130"
          data-css-var="--portal-dot-y"
          data-unit="%"
        />
      </label>

      <label>
        <span>Gap before</span>
        <output></output>
        <input
          type="range"
          min="-0.15"
          max="0.25"
          step="0.002"
          value="0.015"
          data-css-var="--portal-gap-left"
          data-unit="em"
        />
      </label>

      <label>
        <span>Gap after</span>
        <output></output>
        <input
          type="range"
          min="-0.2"
          max="0.25"
          step="0.002"
          value="-0.01"
          data-css-var="--portal-gap-right"
          data-unit="em"
        />
      </label>
    </details>

    <details open>
      <summary>ink</summary>

      <label>
        <span>Color</span>
        <input type="color" value="#2868d8" data-css-var="--ink-mark" />
      </label>

      <label>
        <span>Width</span>
        <output></output>
        <input
          type="range"
          min="0.2"
          max="2"
          step="0.005"
          value="0.83"
          data-css-var="--ink-width"
          data-unit="em"
        />
      </label>

      <label>
        <span>Height</span>
        <output></output>
        <input
          type="range"
          min="0.2"
          max="1.5"
          step="0.005"
          value="0.6"
          data-css-var="--ink-height"
          data-unit="em"
        />
      </label>

      <label>
        <span>Gap</span>
        <output></output>
        <input
          type="range"
          min="-0.3"
          max="0.5"
          step="0.002"
          value="0.035"
          data-css-var="--ink-gap"
          data-unit="em"
        />
      </label>

      <label>
        <span>Vertical offset</span>
        <output></output>
        <input
          type="range"
          min="-0.8"
          max="0.8"
          step="0.005"
          value="0.11"
          data-css-var="--ink-offset-y"
          data-unit="em"
        />
      </label>

      <label>
        <span>Rotation</span>
        <output></output>
        <input
          type="range"
          min="-20"
          max="20"
          step="0.1"
          value="0"
          data-css-var="--ink-rotation"
          data-unit="deg"
        />
      </label>
    </details>

    <details>
      <summary>Current settings</summary>
      <pre data-settings-output></pre>
      <button type="button" data-copy>copy settings</button>
    </details>
  </aside>

  <script>
    const storageKey = "suhail-hero-design-lab-v1";
    const root = document.documentElement;

    const controls = Array.from(
      document.querySelectorAll<HTMLInputElement | HTMLSelectElement>(
        "[data-css-var]",
      ),
    );

    const settingsOutput = document.querySelector<HTMLElement>(
      "[data-settings-output]",
    );

    const resetButton =
      document.querySelector<HTMLButtonElement>("[data-reset]");

    const copyButton = document.querySelector<HTMLButtonElement>("[data-copy]");

    type Settings = Record<string, string>;

    function currentSettings(): Settings {
      return Object.fromEntries(
        controls.map((control) => {
          const variable = control.dataset.cssVar ?? "";
          const unit = control.dataset.unit ?? "";
          return [variable, `${control.value}${unit}`];
        }),
      );
    }

    function renderOutput(): void {
      if (!settingsOutput) return;
      settingsOutput.textContent = JSON.stringify(currentSettings(), null, 2);
    }

    function applyControl(control: HTMLInputElement | HTMLSelectElement): void {
      const variable = control.dataset.cssVar;
      if (!variable) return;

      const unit = control.dataset.unit ?? "";
      const value = `${control.value}${unit}`;

      root.style.setProperty(variable, value);

      const output = control.closest("label")?.querySelector("output");
      if (output) output.textContent = value;
    }

    function save(): void {
      localStorage.setItem(storageKey, JSON.stringify(currentSettings()));
      renderOutput();
    }

    function restore(): void {
      const raw = localStorage.getItem(storageKey);

      if (!raw) {
        controls.forEach(applyControl);
        renderOutput();
        return;
      }

      const settings = JSON.parse(raw) as Settings;

      for (const control of controls) {
        const variable = control.dataset.cssVar;
        if (!variable || !(variable in settings)) continue;

        const unit = control.dataset.unit ?? "";
        control.value = settings[variable].replace(unit, "");
        applyControl(control);
      }

      renderOutput();
    }

    controls.forEach((control) => {
      control.addEventListener("input", () => {
        applyControl(control);
        save();
      });
    });

    resetButton?.addEventListener("click", () => {
      localStorage.removeItem(storageKey);
      window.location.reload();
    });

    copyButton?.addEventListener("click", async () => {
      await navigator.clipboard.writeText(
        JSON.stringify(currentSettings(), null, 2),
      );

      copyButton.textContent = "copied";

      window.setTimeout(() => {
        copyButton.textContent = "copy settings";
      }, 1200);
    });

    restore();
  </script>

  <style>
    .design-lab-preview {
      min-height: 100svh;
    }

    .design-lab-panel {
      position: fixed;
      z-index: 100;
      top: 1rem;
      left: 1rem;
      width: min(22rem, calc(100vw - 2rem));
      max-height: calc(100svh - 2rem);
      overflow: auto;
      padding: 0.8rem;
      border: 1px solid rgb(127 127 127 / 25%);
      border-radius: 1rem;
      background: rgb(20 20 20 / 88%);
      color: #f5f5f5;
      box-shadow: 0 1rem 4rem rgb(0 0 0 / 24%);
      font:
        12px/1.4 ui-monospace,
        SFMono-Regular,
        Menlo,
        monospace;
      backdrop-filter: blur(20px);
    }

    .design-lab-panel__header {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.25rem 0.25rem 0.75rem;
    }

    .design-lab-panel__header strong,
    .design-lab-panel__header small {
      display: block;
    }

    .design-lab-panel__header small {
      margin-top: 0.2rem;
      color: #aaa;
    }

    .design-lab-panel details {
      padding: 0.65rem 0.25rem;
      border-top: 1px solid rgb(255 255 255 / 14%);
    }

    .design-lab-panel summary {
      margin-bottom: 0.65rem;
      cursor: pointer;
      font-weight: 700;
    }

    .design-lab-panel label {
      display: grid;
      grid-template-columns: minmax(6rem, 1fr) auto;
      gap: 0.25rem 0.75rem;
      align-items: center;
      margin: 0.55rem 0;
    }

    .design-lab-panel label input[type="range"],
    .design-lab-panel label input[type="text"],
    .design-lab-panel label select {
      grid-column: 1 / -1;
      width: 100%;
      min-width: 0;
    }

    .design-lab-panel label select {
      padding: 0.45rem 0.5rem;
      border: 1px solid rgb(255 255 255 / 22%);
      border-radius: 0.45rem;
      background: #222;
      color: #f5f5f5;
    }

    .design-lab-panel input,
    .design-lab-panel button {
      font: inherit;
    }

    .design-lab-panel button {
      padding: 0.35rem 0.55rem;
      border: 1px solid rgb(255 255 255 / 22%);
      border-radius: 0.45rem;
      background: rgb(255 255 255 / 8%);
      color: inherit;
      cursor: pointer;
    }

    .design-lab-panel output {
      color: #9fc1ff;
      text-align: right;
    }

    .design-lab-panel pre {
      max-height: 16rem;
      overflow: auto;
      padding: 0.7rem;
      border-radius: 0.5rem;
      background: rgb(0 0 0 / 32%);
      white-space: pre-wrap;
    }

    @media (max-width: 720px) {
      .design-lab-panel {
        top: auto;
        bottom: 0.5rem;
        left: 0.5rem;
        width: calc(100vw - 1rem);
        max-height: 45svh;
      }
    }
  </style>
</SiteLayout>
