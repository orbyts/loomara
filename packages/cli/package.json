{
  "name": "loomara",
  "version": "0.0.0",
  "description": "Artifact-driven website assembler and publishing toolkit.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "loomara": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/orbyts/loomara.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/orbyts/loomara/issues"
  },
  "homepage": "https://github.com/orbyts/loomara#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
